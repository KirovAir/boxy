@model UploaderVm
@* The one chunked uploader (upload.js): drag-drop or click, live progress + resume. The plain
   multipart post is the no-JS fallback. Render once per page. *@
<form id="uploadForm" method="post" action="@Model.Action" enctype="multipart/form-data"
      data-chunk-url="@Model.ChunkUrl" data-complete-url="@Model.CompleteUrl"
      data-reload="@(Model.Reload ? "true" : null)" data-delete-base="@Model.DeleteBase"
      data-max-bytes="@(Model.MaxBytes > 0 ? Model.MaxBytes.ToString() : null)">
    @if (Model.Antiforgery)
    {
        @Html.AntiForgeryToken()
    }
    <label class="dropzone mb-3">
        <input type="file" name="@Model.InputName" multiple="@(Model.Multiple ? "multiple" : null)"/>
        <span class="up-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline
                    points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </span>
        <div class="up-title">@Model.Title</div>
        <div class="small">@Model.Hint</div>
    </label>
    @* Always visible, never revealed on picking a video: upload.js starts the upload the moment a file
       lands, so a control that appeared then would be frozen in the same tick it showed up. The value is
       read at finalize instead, which also means it stays the uploader's to change while a big clip is
       still on its way up. *@
    @if (Model.ConversionOption)
    {
        <div class="mb-3">
            <label class="form-label" for="profile">Video conversion</label>
            <select name="profile" id="profile" class="form-select mb-1" style="max-width: 24rem;">
                @foreach (var p in ConversionProfiles.Choices)
                {
                    <option value="@p" selected="@(p == Model.DefaultProfile)"
                            data-help="@ConversionProfiles.Help(p)">@ConversionProfiles.Label(p)</option>
                }
            </select>
            @* The cost of the option you are on stays in front of you, rather than being buried in docs. *@
            <div class="form-text" id="profileHelp">@ConversionProfiles.Help(Model.DefaultProfile)</div>
            <div class="form-text">Only videos are affected. Everything else is stored exactly as it came in.</div>
        </div>
    }
    <button type="submit" class="btn btn-primary">@Model.ButtonText</button>
</form>
<ul class="list-group mt-3" id="queue"></ul>
<div id="readout" class="alert alert-secondary py-2 small mt-3 d-none"></div>
