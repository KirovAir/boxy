@model ShareViewModel
@{
    Layout = null;
    var isVideo = Model.Kind == MediaKind.Video;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>@Brand.Title(Model.Title)</title>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <meta name="description" content="@Model.Description"/>
    }

    @* ── OpenGraph: rendered server-side so chat apps/crawlers get a rich preview ── *@
    <meta property="og:type" content="@(isVideo ? "video.other" : "website")"/>
    <meta property="og:site_name" content="Boxy"/>
    <meta property="og:title" content="@Model.Title"/>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <meta property="og:description" content="@Model.Description"/>
    }
    <meta property="og:url" content="@Model.PageUrl"/>
    <meta property="og:image" content="@Model.OgImageUrl"/>
    @if (isVideo)
    {
        <meta property="og:video" content="@Model.FileUrl"/>
        <meta property="og:video:secure_url" content="@Model.FileUrl"/>
        <meta property="og:video:type" content="@Model.ContentType"/>
        @if (Model.Width is not null)
        {
            <meta property="og:video:width" content="@Model.Width"/>
            <meta property="og:video:height" content="@Model.Height"/>
        }
    }

    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="@Model.Title"/>
    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <meta name="twitter:description" content="@Model.Description"/>
    }
    <meta name="twitter:image" content="@Model.OgImageUrl"/>

    <link rel="icon" type="image/png" href="/img/favicon.png" asp-append-version="true"/>
    <link rel="apple-touch-icon" href="/img/apple-touch-icon.png" asp-append-version="true"/>
    <link rel="stylesheet" href="/lib/bootstrap/css/bootstrap.min.css" asp-append-version="true"/>
    <link rel="stylesheet" href="/css/custom.css" asp-append-version="true"/>
</head>
<body class="share-page">
<main class="share-main">
    @* Content first: the shared file is the hero; the brand signs off in the footer. *@
    @if (Model.Kind == MediaKind.Video)
    {
        // Fill the viewport (aspect preserved) so the video is big by default; native controls carry fullscreen.
        var fit = Model.Width is int vw && Model.Height is int vh && vw > 0 && vh > 0
            ? $"width:min(96vw, 1600px, calc(85vh * {vw} / {vh}));aspect-ratio:{vw} / {vh}"
            : "width:min(96vw, 1600px);max-height:85vh";
        <video class="share-video" controls playsinline preload="metadata" poster="@Model.PosterUrl" style="@fit">
            <source src="@Model.FileUrl" type="@Model.ContentType"/>
            Your browser can’t play this video.
        </video>
    }
    <div class="share-body">
        @if (Model.Kind == MediaKind.Image)
        {
            <a href="@Model.FileUrl" target="_blank" rel="noopener"><img src="@Model.FileUrl" alt="@Model.Title"
                                                                         class="share-media"/></a>
        }
        else if (Model.Kind == MediaKind.Pdf)
        {
            <iframe src="@Model.FileUrl" class="share-pdf" title="@Model.Title"></iframe>
        }
        else if (Model.Kind == MediaKind.Audio)
        {
            <div class="share-file">
                <div class="share-file__icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M9 18V5l12-2v13"/>
                        <circle cx="6" cy="18" r="3"/>
                        <circle cx="18" cy="16" r="3"/>
                    </svg>
                </div>
                <div class="share-file__name">@(Model.OriginalFileName ?? Model.Title)</div>
                <audio controls src="@Model.FileUrl" style="width:100%;margin-top:1rem"></audio>
            </div>
        }
        else if (Model.Kind == MediaKind.File)
        {
            <div class="share-file">
                <div class="share-file__icon">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"
                         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <path d="M14 2v6h6"/>
                    </svg>
                </div>
                <div class="share-file__name">@(Model.OriginalFileName ?? Model.Title)</div>
                <div class="share-file__meta">@Human(Model.SizeBytes)</div>
                @if (Model.CanDownload)
                {
                    <a href="@Model.DownloadUrl" class="btn btn-primary">Download</a>
                }
                else if (Model.DownloadLimitReached)
                {
                    <div class="text-secondary small">Download limit reached.</div>
                }
            </div>
        }

        <div class="share-info">
            <h1 class="share-title">@Model.Title</h1>
            <div class="share-meta">
                <span class="text-secondary small">@Model.Views view@(Model.Views == 1 ? "" : "s")</span>
                <button id="likeBtn" type="button"
                        class="btn btn-sm @(Model.LikedByMe ? "btn-danger" : "btn-outline-light")"
                        data-slug="@Model.Slug">
                    ♥ <span id="likeCount">@Model.Likes</span>
                </button>
                @if (Model.Kind != MediaKind.File && Model.CanDownload)
                {
                    <a href="@Model.DownloadUrl"
                       class="btn btn-sm btn-outline-light">Download@(Model.Kind == MediaKind.Video ? " original" : "")</a>
                }
                else if (Model.Kind != MediaKind.File && Model.DownloadLimitReached)
                {
                    <span class="text-secondary small">Download limit reached</span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="share-desc">@Model.Description</div>
            }
        </div>
    </div>
</main>
<partial name="_Footer"/>
<script>
    (function () {
        // iOS gives up for good when a range request dies mid-stream (a scrub burst tripping the
        // proxy, a Wi-Fi/cellular hand-off): the element lands in a fatal error or an endless stall
        // and the native controls never retry. Desktop browsers reconnect on their own. So remember
        // the position, reload the source, seek back and resume - capped, so a genuinely dead link
        // still surfaces the browser's error UI instead of looping.
        var media = document.querySelector('video.share-video, .share-file audio');
        if (!media) return;

        var attempts = 0;
        var lastTime = 0;
        var stuckMs = 0;

        function recover() {
            if (attempts >= 3) return;
            attempts++;
            var at = media.currentTime;
            var resume = !media.paused && !media.ended;
            media.load();
            media.addEventListener('loadedmetadata', function seekBack() {
                media.removeEventListener('loadedmetadata', seekBack);
                if (at > 0) media.currentTime = at;
                if (resume) {
                    var p = media.play();
                    if (p && p.catch) p.catch(function () {});
                }
            });
        }

        media.addEventListener('error', recover);
        var source = media.querySelector('source');
        if (source) source.addEventListener('error', function () {
            // A source error before anything ever played means the format is unsupported: let the
            // fallback text show. After playback started it means the connection died: recover.
            if (media.currentTime > 0) recover();
        });

        // The silent failure mode: no error event, the pipeline just stops making progress. If the
        // clock hasn't moved for 15s while it should be playing and buffering, kick the same recovery.
        setInterval(function () {
            if (media.paused || media.ended) {
                stuckMs = 0;
            } else if (media.currentTime !== lastTime) {
                stuckMs = 0;
                attempts = 0; // real progress again: future hiccups may recover anew
            } else if (media.readyState < 3) { // below HAVE_FUTURE_DATA: starved, not just idle
                stuckMs += 3000;
                if (stuckMs >= 15000) {
                    stuckMs = 0;
                    recover();
                }
            }
            lastTime = media.currentTime;
        }, 3000);
    })();

    (function () {
        var likeBtn = document.getElementById('likeBtn');
        if (!likeBtn) return;
        likeBtn.addEventListener('click', function () {
            likeBtn.disabled = true;
            fetch('/api/media/' + likeBtn.getAttribute('data-slug') + '/like', {method: 'POST'})
                .then(function (r) {
                    return r.ok ? r.json() : null;
                })
                .then(function (d) {
                    if (d) {
                        document.getElementById('likeCount').textContent = d.likes;
                        likeBtn.className = 'btn btn-sm ' + (d.liked ? 'btn-danger' : 'btn-outline-light');
                    }
                })
                .catch(function () {
                })
                .then(function () {
                    likeBtn.disabled = false;
                });
        });
    })();
</script>
</body>
</html>

@functions {

    private static string Human(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        double n = bytes;
        var u = 0;
        while (n >= 1024 && u < units.Length - 1)
        {
            n /= 1024;
            u++;
        }

        return $"{n:0.#} {units[u]}";
    }

}
